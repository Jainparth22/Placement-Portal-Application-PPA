# ─────────────────────────────────────────────────────────────────
# PPA — Placement Portal Application  |  .env.example
# Copy this file to .env and fill in your actual values.
# .env is gitignored and should NEVER be committed to the repo.
# ─────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=your-flask-secret-key-here
FLASK_ENV=development           # development | production
FLASK_DEBUG=1                   # 1 = on, 0 = off

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here

# Admin credentials (auto-created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Redis (required for Celery + caching)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email (Gmail SMTP — use an App Password, not your real password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Google Chat Webhook (optional — for admin notifications)
GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages?key=YOUR_KEY&token=YOUR_TOKEN
